              "type": "column",
              "align": "center",
              "flex": 3,
              "scrollable": false,
              "content": "\n\n### The Everyone Tax\n\nComplex apps burden everyone with features built for others.\n"
            },
            {
              "type": "column",
              "flex": 1,
              "scrollable": false
            }
          ]
        }
